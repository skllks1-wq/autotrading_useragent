# AutoTrading User Agent - 환경변수 설정
# Railway 환경변수에 아래 항목들을 설정하세요

# 거래소 설정
EXCHANGE=bybit                          # bybit | okx | bitget | bingx
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=                         # OKX만 필요

# 추천인 코드 (파트너의 본사 코드 — 에이전트 등록 시 전달)
PARTNER_CODE=

# Agent 인증 (앱 설정 → Agent 탭에서 발급)
# 형식: {supabase_user_id}:{32바이트_hex}  (토큰 1개만 입력, AGENT_USER_ID 불필요)
AGENT_TOKEN=your_agent_token_here

# 중앙 서버 URL
CENTRAL_URL=https://your-central-server.railway.app
